# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# GitHub Personal Access Token with read:project scope
# Create one at: https://github.ibm.com/settings/tokens
PROJECT_TOKEN=ghp_yourTokenHere

# GraphQL node ID of the GitHub Project board (starts with PVT_)
# Find it by running:
#   curl -s -H "Authorization: Bearer YOUR_PAT" \
#     -H "Content-Type: application/json" \
#     -d '{"query":"{ organization(login: \"Db2z\") { projectsV2(first: 50) { nodes { id title } } } }"}' \
#     https://github.ibm.com/api/graphql
PROJECT_ID=PVT_yourProjectIdHere

# GitHub Enterprise API endpoint (required for github.ibm.com)
GITHUB_API_URL=https://github.ibm.com/api/graphql
